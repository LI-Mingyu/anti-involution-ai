// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 届次
model Season {
  id        String    @id @default(cuid())
  name      String    // e.g. "第一届"
  status    String    @default("UPCOMING") // UPCOMING | ACTIVE | ARCHIVED
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime  @default(now())

  projects    Project[]
  submissions Submission[]
}

// AI 项目
model Project {
  id              String   @id @default(cuid())
  slug            String   @unique // URL slug，唯一标识
  name            String
  description     String
  longDescription String?  // 详细介绍，支持 Markdown
  url             String   // 体验链接
  githubUrl       String?  // GitHub / 官网链接（可选）
  imageUrl        String?
  award           String?  // UNREPLACEABLE | USELESS | null
  judgeComment    String?  // 评委点评内容
  judgeNickname   String?  // 评委昵称
  isActive        Boolean  @default(true) // false 表示已下架
  seasonId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  season      Season       @relation(fields: [seasonId], references: [id])
  likes       Like[]
  comments    Comment[]
  submissions Submission[] // 关联的自荐/提名记录
}

// 提名 / 自荐
model Submission {
  id                 String   @id @default(cuid())
  projectName        String
  projectUrl         String
  description        String
  submitterEmail     String?
  submitterNickname  String?  // 自荐人昵称
  isPublic           Boolean  @default(false) // 是否公开自荐人信息
  status             String   @default("PENDING") // PENDING | APPROVED | REJECTED
  seasonId           String
  projectId          String?  // 审批通过后关联到的项目（可选）
  createdAt          DateTime @default(now())

  season  Season   @relation(fields: [seasonId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
}

// 点赞（无需注册，fingerprint 防刷）
model Like {
  id          String   @id @default(cuid())
  projectId   String
  fingerprint String   // browser fingerprint for dedup
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, fingerprint])
}

// 评论（匿名）
model Comment {
  id        String   @id @default(cuid())
  projectId String
  content   String
  nickname  String   @default("匿名用户")
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}
